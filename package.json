{
  "name": "cf-mail",
  "version": "0.1.0",
  "description": "A self-hosted mailbox that runs entirely on Cloudflare: Email Routing + Workers + D1 + R2, with a built-in web client and optional push notifications.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "tsc --noEmit && wrangler deploy --dry-run --outdir dist"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "postal-mime": "^2.3.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250923.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
